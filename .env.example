# Скопируйте этот файл в .env и заполните реальными значениями.
# Никогда не публикуйте .env с реальным токеном в открытом репозитории.

# Токен бота: получите у @BotFather в Telegram (команда /newbot)
TELEGRAM_BOT_TOKEN=

# ID чата, куда бот будет присылать репорты об ошибках
# (личный чат с ботом, группа или канал — бот должен быть туда добавлен)
TELEGRAM_CHAT_ID=
